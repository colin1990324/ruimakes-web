---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "Zyklop棘轮扳手-收纳盒 | ruimakes";
const pageDesc = "为 Wera Zyklop 棘轮扳手系列设计的收纳盒，小飞中飞分别定位，Wera 绿标志性配色。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/storage/zyklop/小飞-8100SA6-28件套/IMG_7166.webp" alt="Zyklop棘轮扳手-收纳盒 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-green-400 mb-3 uppercase tracking-widest font-bold">Tool Organization</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            <span class="text-green-400">Zyklop</span> 棘轮扳手-收纳盒
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            为 Wera Zyklop 棘轮扳手系列设计的收纳系统。小飞（8100SA6）、中飞（8100SB6）各有专属凹槽，磁吸定位，Wera 绿标志性配色，让工具墙成为工作坊焦点。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-green-400">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 定制尺寸</span>
          </div>
          <a href="/contact" class="inline-block bg-green-500 text-zinc-900 px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">专位专用</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">基于 Zyklop 棘轮扳手实物 1:1 建模，小飞中飞各有专属槽位。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">磁吸定位</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">磁吸式嵌入设计，放入自动对齐，稳固不晃动。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">Wera 绿配色</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">精准还原 Wera 标志性绿色，品牌致敬与功能统一。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">模块化扩展</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">单一收纳盒可无限扩展，选购不同模块定制专属工具墙。</p>
      </div>
    </div>

    <ProductSpecs brand="Wera" material="PETG（环保无毒）" compatibility="Wera Zyklop 8100SA6 / 8100SB6 系列" features={["专位专用", "磁吸定位", "Wera绿配色", "模块化扩展"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/storage/zyklop/小飞-8100SA6-28件套/IMG_7166.webp" alt="Zyklop 小飞" class="rounded-sm border border-border-zinc" />
      <img src="/images/storage/zyklop/中飞-8100SB6-29件套/IMG_7161.webp" alt="Zyklop 中飞" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
  </footer>
</Layout>