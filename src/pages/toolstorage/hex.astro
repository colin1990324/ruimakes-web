---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "内六角-收纳盒 | ruimakes";
const pageDesc = "为内六角扳手套装设计的收纳盒，精准凹槽，磁吸定位，支持多种规格尺寸。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/storage/hex/IMG_4582.webp" alt="内六角-收纳盒 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-green-400 mb-3 uppercase tracking-widest font-bold">Tool Organization</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            <span class="text-green-400">内六角</span> 收纳盒
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            为内六角扳手套装设计的收纳盒。精准凹槽，磁吸定位，支持多种规格尺寸（S2 / 2.5 / 3 / 4 / 5 / 6mm 等），每一把都有专属位置。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-green-400">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 定制尺寸</span>
          </div>
          <a href="#" class="inline-block bg-green-500 text-zinc-900 px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">多规格支持</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">支持 S2 / 2.5 / 3 / 4 / 5 / 6mm 等多种规格，定制专属凹槽。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">磁吸定位</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">磁吸式嵌入设计，工具放入自动对齐，稳固不晃动。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">专位专用</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">基于实物精准测量，确保每一把扳手都有专属位置。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">便携设计</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">盒体轻巧便携，工作台和现场都能轻松使用。</p>
      </div>
    </div>

    <ProductSpecs brand="Wera" material="PETG（环保无毒）" compatibility="内六角扳手套装（S2-6mm）" features={["多规格支持", "磁吸定位", "专位专用", "便携设计"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/storage/hex/IMG_4582.webp" alt="内六角 收纳盒 1" class="rounded-sm border border-border-zinc" />
      <img src="/images/storage/hex/IMG_4583.webp" alt="内六角 收纳盒 2" class="rounded-sm border border-border-zinc" />
      <img src="/images/storage/hex/IMG_4786.webp" alt="内六角 收纳盒 3" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
  </footer>
</Layout>