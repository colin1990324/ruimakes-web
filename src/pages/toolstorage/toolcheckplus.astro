---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "ToolCheckPlus 收纳盒 | ruimakes";
const pageDesc = "为 Wera / PB Swiss / Knipex 等顶级工具设计的 3D 打印收纳盒。专位专用，磁吸定位，模块化扩展，让工具收纳达到工业美学水准。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img 
            src="/images/storage/IMG_7869.webp" 
            alt="ToolCheckPlus 收纳盒"
            class="w-full rounded-sm shadow-2xl border border-border-zinc"
          />
        </div>
        
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Tool Organization</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            <span class="text-wera-green">ToolCheckPlus</span> 收纳盒
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            专为 Wera / PB Swiss / Knipex 等顶级工具设计的 3D 打印收纳系统。每一个凹槽都经过精密测量，确保工具"咔哒"一声完美就位。磁吸定位 + 模块化扩展，让你的工具墙成为工作坊的视觉焦点。
          </p>
          
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥199</span>
            <span class="text-zinc-500 text-sm">/ 起（定制尺寸）</span>
          </div>

          <a href="#" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">
            咨询购买
          </a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">专位专用</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">
          每一个凹槽都基于实物 1:1 建模。批头、螺丝刀、钳子各有归属，工具永远在它该在的位置。
        </p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">磁吸定位</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">
          磁吸式嵌入设计，工具放入时自动对齐。凹槽内嵌软性硅胶垫，保护工具镀层不受刮擦。
        </p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">原厂色匹配</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">
          精准还原 Wera 绿、PB Swiss 红、Knipex 蓝的品牌色系。不仅是收纳，更是展示。
        </p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">模块化扩展</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">
          单一收纳盒可无限扩展。选购不同模块，定制专属工具墙布局。
        </p>
      </div>
    </div>

    <ProductSpecs
      brand="Wera"
      material="PETG（环保无毒）"
      compatibility="Wera / PB Swiss / Knipex 工具"
      features={["专位专用", "磁吸定位", "原厂色匹配", "模块化扩展"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">收纳逻辑</h2>
    <div class="bg-card-bg border border-border-zinc rounded-sm p-6 overflow-x-auto">
      <pre class="text-wera-green text-sm">工具入库 → 磁吸定位 → 精准卡位 → 状态可视化 → 快速取用</pre>
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES SECURITY LABS // RUIS-MBP-15
  </footer>
</Layout>