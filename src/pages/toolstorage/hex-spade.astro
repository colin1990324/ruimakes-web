---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "内六角-梅花-插座 | ruimakes";
const pageDesc = "内六角与梅花扳手两用插座式收纳设计，精准凹槽适配多种规格，磁吸定位。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/storage/hex-spade/实拍图/IMG_6186.webp" alt="内六角-梅花-插座 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-green-400 mb-3 uppercase tracking-widest font-bold">Tool Organization</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            <span class="text-green-400">内六角-梅花</span> 插座
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            内六角与梅花扳手两用插座式收纳设计。精准凹槽适配多种规格，磁吸定位，专位专用，让插座式工具管理更高效。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-green-400">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 定制尺寸</span>
          </div>
          <a href="#" class="inline-block bg-green-500 text-zinc-900 px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">两用设计</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">内六角与梅花扳手两用设计，一盒多能，节省空间。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">插座式收纳</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">插座式设计，工具垂直插入，取用更方便。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">磁吸定位</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">磁吸式嵌入，工具放入自动对齐，稳固不晃动。</p>
      </div>
      <div class="bg-card-bg border border-green-500 rounded-sm p-6">
        <h3 class="text-lg font-bold text-green-400 mb-3">多规格支持</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">支持多种规格定制，适配不同工具尺寸需求。</p>
      </div>
    </div>

    <ProductSpecs brand="Wera" material="PETG（环保无毒）" compatibility="内六角/梅花扳手套装" features={["两用设计", "插座式收纳", "磁吸定位", "多规格支持"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/storage/hex-spade/实拍图/IMG_6186.webp" alt="内六角-梅花-插座 1" class="rounded-sm border border-border-zinc" />
      <img src="/images/storage/hex-spade/实拍图/IMG_6187.webp" alt="内六角-梅花-插座 2" class="rounded-sm border border-border-zinc" />
      <img src="/images/storage/hex-spade/实拍图/IMG_6188.webp" alt="内六角-梅花-插座 3" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES SECURITY LABS // RUIS-MBP-15
  </footer>
</Layout>