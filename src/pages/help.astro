---
import Layout from '../layouts/Layout.astro';

const pageTitle = "帮助中心 | ruimakes";
const pageDesc = "Ruimakes 购买流程、配送说明、售后服务、联系客服";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-extrabold text-zinc-100 mb-12">帮助中心</h1>
    
    <!-- 目录 -->
    <div class="flex flex-wrap gap-4 mb-12">
      <a href="#流程" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        购买流程
      </a>
      <a href="#配送" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        配送说明
      </a>
      <a href="#售后" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        售后服务
      </a>
      <a href="#联系" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        联系客服
      </a>
      <a href="#定制" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        定制说明
      </a>
      <a href="#附录" class="px-4 py-2 bg-zinc-800 border border-border-zinc rounded-sm text-zinc-300 hover:text-wera-green hover:border-wera-green transition-colors">
        附录
      </a>
    </div>
    
    <!-- 购买流程 -->
    <section id="流程" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">01</span> 购买流程
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6">
        <ol class="space-y-6 text-zinc-300">
          <li class="flex gap-4">
            <span class="text-wera-green font-bold">1.</span>
            <div>
              <div class="font-bold text-zinc-100 mb-1">选择产品</div>
              <p class="text-zinc-400 text-sm">在店铺中选择您需要的工具收纳产品，或联系客服定制。</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-wera-green font-bold">2.</span>
            <div>
              <div class="font-bold text-zinc-100 mb-1">确认订单</div>
              <p class="text-zinc-400 text-sm">客服确认产品配置、价格和交货时间。</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-wera-green font-bold">3.</span>
            <div>
              <div class="font-bold text-zinc-100 mb-1">支付</div>
              <p class="text-zinc-400 text-sm">通过淘宝/小红书/闲鱼/拼多多支付定金或全款。</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-wera-green font-bold">4.</span>
            <div>
              <div class="font-bold text-zinc-100 mb-1">生产发货</div>
              <p class="text-zinc-400 text-sm">定制产品5-7天发货，现货1-2天发货。散件发货，需DIY组装。</p>
            </div>
          </li>
        </ol>
      </div>
    </section>
    
    <!-- 配送说明 -->
    <section id="配送" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">02</span> 配送说明
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6 space-y-4">
        <div>
          <div class="font-bold text-zinc-100 mb-2">发货方式</div>
          <p class="text-zinc-400 text-sm">散件发货，DIY组装（类似拼乐高），随含详细安装视频和图纸。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">配件</div>
          <p class="text-zinc-400 text-sm">所有产品含安装配件，部分产品需自备内角扳手和手电钻（随产品附送3mm钻头）。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">发货时效</div>
          <p class="text-zinc-400 text-sm">定制产品5-7天发货，部分产品有现货（需与客服确认）。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">运费</div>
          <p class="text-zinc-400 text-sm">全国大部分地区包邮（偏远地区除外）。</p>
        </div>
      </div>
    </section>
    
    <!-- 售后服务 -->
    <section id="售后" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">03</span> 售后服务
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6 space-y-4">
        <div>
          <div class="font-bold text-zinc-100 mb-2">质保期限</div>
          <p class="text-zinc-400 text-sm">铝型材框架结构终身质保，实木桌面/配件因人为损坏不在质保范围内。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">免费维修</div>
          <p class="text-zinc-400 text-sm">非人为损坏的框架结构问题，提供免费维修或更换。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">配件更换</div>
          <p class="text-zinc-400 text-sm">配件（如福马轮、地脚等）损坏可单独购买更换。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">颜色差异</div>
          <p class="text-zinc-400 text-sm">实木桌面存在天然色差，属于正常现象。</p>
        </div>
      </div>
    </section>
    
    <!-- 联系客服 -->
    <section id="联系" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">04</span> 联系客服
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6">
        <p class="text-zinc-400 mb-6">
          如有任何问题，欢迎通过以下渠道联系我们：
        </p>
        <div class="grid md:grid-cols-2 gap-4">
          <a href="/contact" class="p-4 bg-zinc-900 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
            <div class="font-bold text-zinc-100">在线客服</div>
            <p class="text-zinc-500 text-sm">淘宝/小红书/闲鱼/拼多多店铺</p>
          </a>
        </div>
      </div>
    </section>
    
    <!-- 定制说明 -->
    <section id="定制" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">05</span> 定制说明
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6 space-y-6">
        <div>
          <div class="font-bold text-zinc-100 mb-2">1. 铝型材定制</div>
          <p class="text-zinc-400 text-sm">默认使用欧标3030Q铝型材。可按需定制欧标3030L喷砂黑（需额外收费），使用其他加厚款铝型材也会增加费用。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">2. 桌面材质</div>
          <p class="text-zinc-400 text-sm">桌面采用北美进口樱桃原木多拼而成（2cm厚），存在天然纹理、色差和固有属性。拼板师傅会选定木材一面为正面，将存在天然缺陷的部分修复后置于背面，保证正面可用度较好。默认仅正面刷多层木蜡油，如果双面都需要油漆封闭（需额外收费）。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">3. 颜色定制</div>
          <p class="text-zinc-400 text-sm">所有板材默认为樱桃木色，可按照客户要求改为黑胡桃木色等（不额外收费）。改色采用环保改色漆。抽屉板、下托板等辅材采用国产白椿木改樱桃木色，也为实木。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">4. 福马轮配置</div>
          <p class="text-zinc-400 text-sm">默认均采用40S福马轮，铝型材已提前攻丝M8，手动即可安装。40S福马轮单个称重50KG，4只可载重200KG，可放心使用。福马轮有可调节支腿，支腿伸出时整个桌子会非常稳固。144款增加了2只40F福马轮作为中间支撑。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">5. 费斯托工具箱</div>
          <p class="text-zinc-400 text-sm">产品包含正品费斯托Festool工具箱，产品价格已包含对应工具箱价格。抽屉部分含：三节轨、定制箱拖、工具箱、承重光轴，单个工具箱载重20kg。工具箱收纳状态做抽屉用，取出状态可做便携工具箱日常携带。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">6. 长度定制</div>
          <p class="text-zinc-400 text-sm">85款、97款、144款均为固定长度，长度无法变化。120款从97款加长而来，可定制长度120-140cm。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">7. 宽度定制</div>
          <p class="text-zinc-400 text-sm">拓竹P系列默认40cm，可定制加宽。H系列默认52cm，可定制加宽。</p>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">8. 高度定制</div>
          <p class="text-zinc-400 text-sm">85款内空高度50cm，原则上不定制。97款、120款、144款内空高度65cm，原则上不定制。</p>
        </div>
      </div>
    </section>
    
    <!-- 附录 -->
    <section id="附录" class="mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-zinc-100 mb-6 flex items-center gap-3">
        <span class="text-wera-green">06</span> 附录
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-6 space-y-6">
        <div>
          <div class="font-bold text-zinc-100 mb-2">拓竹打印机外尺寸</div>
          <div class="text-zinc-400 text-sm space-y-2">
            <p>P1系列：长386mm × 宽389mm × 高458mm</p>
            <p>P2系列：长392mm × 宽406mm × 高478mm</p>
            <p>X1系列：长389mm × 宽389mm × 高457mm</p>
            <p>X2系列：长392mm × 宽406mm × 高478mm</p>
            <p>H系列：长492mm × 宽514mm × 高626mm</p>
            <p>AMS：长368mm × 宽283mm × 高224mm</p>
            <p>AMS2：长372mm × 宽280mm × 高226mm</p>
            <p>AMS HT：长114mm × 宽280mm × 高245mm</p>
          </div>
        </div>
        <div>
          <div class="font-bold text-zinc-100 mb-2">电子干燥箱尺寸（需自行购买）</div>
          <div class="text-zinc-400 text-sm space-y-2">
            <p>安德宝30L：29cm × 32cm × 41.5cm</p>
            <p>爱宝65L：38cm × 39cm × 52cm</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>