---
import Layout from '../layouts/Layout.astro';

const pageTitle = "联系我们 | ruimakes";
const pageDesc = "联系Ruimakes - 淘宝、小红书、闲鱼、拼多多购买渠道";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-extrabold text-zinc-100 mb-8">联系我们</h1>
    
    <p class="text-zinc-400 mb-8">
      您可以通过以下渠道联系我们或购买产品：
    </p>
    
    <!-- 淘宝 -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-zinc-100 mb-4 flex items-center gap-2">
        <img src="https://img.icons8.com/color/24/taobao.png" alt="淘宝" class="w-6 h-6" />
        淘宝
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-4">
        <p class="text-zinc-400 text-sm mb-2">店铺：ruimakes</p>
        <a href="https://shop576260935.taobao.com" target="_blank" rel="noopener" class="text-wera-green hover:underline">
          https://shop576260935.taobao.com
        </a>
      </div>
    </div>
    
    <!-- 小红书 -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-zinc-100 mb-4 flex items-center gap-2">
        <img src="https://img.icons8.com/color/24/xiaohongshu.png" alt="小红书" class="w-6 h-6" />
        小红书
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-4">
        <p class="text-zinc-400 text-sm mb-2">推荐好店 Ruimakes</p>
        <a href="https://www.xiaohongshu.com/shop/67d62c9a5287a700159fb828" target="_blank" rel="noopener" class="text-wera-green hover:underline">
          https://www.xiaohongshu.com/shop/67d62c9a5287a700159fb828
        </a>
      </div>
    </div>
    
    <!-- 闲鱼 -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-zinc-100 mb-4 flex items-center gap-2">
        <span>闲鱼</span>
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-4">
        <a href="https://www.goofish.com/personal?userId=21951193" target="_blank" rel="noopener" class="text-wera-green hover:underline">
          https://www.goofish.com/personal?userId=21951193
        </a>
      </div>
    </div>
    
    <!-- 拼多多 -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-zinc-100 mb-4 flex items-center gap-2">
        <span>拼多多</span>
      </h2>
      <div class="bg-zinc-800 border border-border-zinc rounded-sm p-4">
        <a href="https://mobile.yangkeduo.com/mall_page.html?_x_org=2&_x_query=ruimakes" target="_blank" rel="noopener" class="text-wera-green hover:underline">
          https://mobile.yangkeduo.com/mall_page.html?_x_query=ruimakes
        </a>
      </div>
    </div>
    
    <!-- 移动端快捷方式 -->
    <div class="mt-12 p-6 bg-zinc-800 border border-border-zinc rounded-sm">
      <h2 class="text-xl font-bold text-zinc-100 mb-4">移动端购买</h2>
      
      <div class="space-y-4">
        <div class="text-zinc-400 text-sm">
          <p class="mb-2">【淘宝】复制以下内容打开淘宝：</p>
          <code class="block bg-zinc-900 p-2 rounded text-wera-green text-xs break-all">
            39🔐9zVU5Ns32zU🔐 https://m.tb.cn/h.iycYpTitezOkBuW CZ005 ruimakes
          </code>
        </div>
        
        <div class="text-zinc-400 text-sm">
          <p class="mb-2">【小红书】复制以下内容打开小红书：</p>
          <code class="block bg-zinc-900 p-2 rounded text-wera-green text-xs break-all">
            21件商品热卖中 😆 AHExuDGSnTY 😆 https://xhslink.com/m/A5vJFcVU9HR
          </code>
        </div>
        
        <div class="text-zinc-400 text-sm">
          <p class="mb-2">【闲鱼】打开链接查看：</p>
          <a href="https://m.tb.cn/h.iDPRu2z?tk=AiB85NsP2ZB" class="text-wera-green hover:underline text-xs">
            https://m.tb.cn/h.iDPRu2z?tk=AiB85NsP2ZB
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>