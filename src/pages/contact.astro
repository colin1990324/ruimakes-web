---
import Layout from '../layouts/Layout.astro';

const pageTitle = "联系我们 | ruimakes";
const pageDesc = "联系Ruimakes - 淘宝、小红书、闲鱼、拼多多购买渠道";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-extrabold text-zinc-100 mb-8">联系我们</h1>
    
    <p class="text-zinc-400 mb-8">
      您可以通过以下渠道联系我们或购买产品：
    </p>
    
    <!-- PC端链接 -->
    <div class="hidden md:grid grid-cols-2 gap-4 mb-8">
      <a href="https://shop576260935.taobao.com" target="_blank" rel="noopener" 
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <img src="/images/logo/taobao-logo.webp" alt="淘宝" class="h-10 w-10 object-contain" />
        <div>
          <div class="font-bold text-zinc-100">淘宝</div>
          <div class="text-sm text-zinc-500">Ruimakes 官方商城</div>
        </div>
      </a>
      
      <a href="https://www.xiaohongshu.com/shop/67d62c9a5287a700159fb828" target="_blank" rel="noopener"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <img src="/images/logo/xiaohongshu-logo.webp" alt="小红书" class="h-10 w-10 object-contain" />
        <div>
          <div class="font-bold text-zinc-100">小红书</div>
          <div class="text-sm text-zinc-500">Ruimakes 官方店铺</div>
        </div>
      </a>
      
      <a href="https://www.goofish.com/personal?userId=21951193" target="_blank" rel="noopener"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <img src="/images/logo/xiaoyu-logo.webp" alt="闲鱼" class="h-10 w-10 object-contain" />
        <div>
          <div class="font-bold text-zinc-100">闲鱼</div>
          <div class="text-sm text-zinc-500">Ruimakes 官方商城</div>
        </div>
      </a>
      
      <a href="https://mobile.yangkeduo.com/mall_page.html?mall_sn=CgI2WRIIS0xJNU5SeWUaEH%2BdatM9YlOjkfEfcWVH1HoiEO%2FJ%2FNHDiHkJuToseUxJCUooAjAC&decrypt_mall_sn=1&msn=4n5i5w5q4cxubumnlpwrdu6tfe_axbuy&_sop_rcto=YWK4AU_wKm9kn9nXK4OB_1FgTuXTx_3fIjo&mall_type=0&refer_page_el_sn=373286&_x_query=ruimakes&refer_page_name=search_result&refer_page_id=10015_1777975338843_fkk34dm392&refer_page_sn=10015&force_use_web_bundle=1" target="_blank" rel="noopener"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <img src="/images/logo/pinduoduo-logo.webp" alt="拼多多" class="h-10 w-10 object-contain" />
        <div>
          <div class="font-bold text-zinc-100">拼多多</div>
          <div class="text-sm text-zinc-500">Ruimakes 官方商城</div>
        </div>
      </a>
    </div>
    
    <!-- 移动端 Deep Link -->
    <div class="md:hidden space-y-4">
      <a href="taobao://shop576260935" 
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <svg class="w-8 h-8 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0z"/>
        </svg>
        <div>
          <div class="font-bold text-zinc-100">淘宝</div>
          <button class="text-xs text-zinc-500 mt-1" data-copy="39🔐9zVU5Ns32zU🔐 https://m.tb.cn/h.iycYpTitezOkBuW CZ005 ruimakes">点击复制</button>
        </div>
      </a>
      
      <a href="xhslink://"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <svg class="w-8 h-8 text-red-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
        </svg>
        <div>
          <div class="font-bold text-zinc-100">小红书</div>
          <button class="text-xs text-zinc-500 mt-1" data-copy="Ruimakes，21件商品热卖中 https://xhslink.com/m/A5vJFcVU9HR">点击复制</button>
        </div>
      </a>
      
      <a href="suning://"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <svg class="w-8 h-8 text-yellow-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
        </svg>
        <div>
          <div class="font-bold text-zinc-100">闲鱼</div>
          <button class="text-xs text-zinc-500 mt-1" data-copy="https://m.tb.cn/h.iDPRu2z?tk=AiB85NsP2ZB">点击复制</button>
        </div>
      </a>
      
      <a href="pinduoduo://"
         class="flex items-center gap-4 p-4 bg-zinc-800 border border-border-zinc rounded-sm hover:border-wera-green transition-colors">
        <svg class="w-8 h-8 text-red-600" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0z"/>
        </svg>
        <div>
          <div class="font-bold text-zinc-100">拼多多</div>
          <button class="text-xs text-zinc-500 mt-1" data-copy="https://mobile.yangkeduo.com/mall_page.html?_x_query=ruimakes">点击复制</button>
        </div>
      </a>
    </div>
    
    <div class="mt-12 p-6 bg-zinc-800 border border-border-zinc rounded-sm">
      <h2 class="text-xl font-bold text-zinc-100 mb-4">复制说明</h2>
      <p class="text-zinc-400 text-sm">
        点击「点击复制」按钮后，打开对应APP即可自动粘贴内容。
      </p>
    </div>
  </div>
  
  <script>
    document.querySelectorAll('[data-copy]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy;
        await navigator.clipboard.writeText(text);
        btn.textContent = '已复制!';
        setTimeout(() => {
          btn.textContent = '点击复制';
        }, 2000);
      });
    });
  </script>
</Layout>