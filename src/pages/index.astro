---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ruimakes | Organize the Excellence">
  <header class="text-center py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-3">
      <span class="text-zinc-100">rui</span><span class="text-wera-green">makes</span>
    </h1>
    <p class="text-zinc-500 uppercase tracking-[0.3em] text-xs italic">
      Organize the Excellence
    </p>
  </header>

  <main class="flex-1 w-full max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      
      <a href="/ams-drawer-105x52" class="group block bg-card-bg border border-border-zinc rounded-sm overflow-hidden hover:border-wera-green transition-all duration-300 shadow-xl">
        <div class="aspect-video bg-zinc-900 relative overflow-hidden">
          <img 
            src="/images/workstation/105-52-正试图-2台.png" 
            alt="105x52 AMSx2 抽板x1 - 拓竹工作台"
            class="object-cover w-full h-full opacity-80 group-hover:opacity-100 transition-opacity duration-300"
          />
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-zinc-900 to-transparent h-20"></div>
        </div>
        <div class="p-6">
          <div class="text-xs text-wera-green mb-2 uppercase tracking-wider font-bold">01 / Workstation</div>
          <h2 class="text-xl font-bold text-zinc-100 mb-2 group-hover:text-wera-green transition-colors">拓竹工作台系列</h2>
          <p class="text-zinc-400 text-sm">105x52 AMSx2 抽板x1 · 防震增强 · 磁吸定位</p>
        </div>
      </a>

      <a href="/toolcheckplus-storage" class="group block bg-card-bg border border-border-zinc rounded-sm overflow-hidden hover:border-wera-green transition-all duration-300 shadow-xl">
        <div class="aspect-video bg-zinc-900 relative overflow-hidden">
          <img 
            src="/images/storage/IMG_7869.JPG" 
            alt="ToolCheckPlus 收纳盒"
            class="object-cover w-full h-full opacity-80 group-hover:opacity-100 transition-opacity duration-300"
          />
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-zinc-900 to-transparent h-20"></div>
        </div>
        <div class="p-6">
          <div class="text-xs text-wera-green mb-2 uppercase tracking-wider font-bold">02 / Tool-Org</div>
          <h2 class="text-xl font-bold text-zinc-100 mb-2 group-hover:text-wera-green transition-colors">精密工具收纳</h2>
          <p class="text-zinc-400 text-sm">ToolCheckPlus 收纳盒 · 专位专用 · 原厂色匹配</p>
        </div>
      </a>
    </div>

    <div class="bg-card-bg border border-border-zinc rounded-sm p-8 text-center">
      <h3 class="text-lg font-bold text-zinc-200 mb-4">精密工具的数字伴侣</h3>
      <p class="text-zinc-400 text-sm leading-relaxed max-w-2xl mx-auto">
        基于 <strong class="text-zinc-200">Bambu Lab</strong> 的精密制造逻辑，为 <strong class="text-zinc-200">Wera / PB Swiss / Knipex</strong> 等顶级工具构建数字时代的物理秩序。
      </p>
      <div class="mt-6 flex items-center justify-center gap-3">
        <span class="h-2 w-2 rounded-full bg-wera-green animate-pulse"></span>
        <span class="text-xs text-zinc-500 uppercase tracking-widest">Security-by-Design</span>
      </div>
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES SECURITY LABS // RUIS-MBP-15
  </footer>
</Layout>