---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ruimakes | Organize the Excellence">
  <!-- Header -->
  <header class="text-center py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-3">
      <span class="text-zinc-100">rui</span><span class="text-wera-green">makes</span>
    </h1>
    <p class="text-zinc-500 uppercase tracking-[0.3em] text-xs italic">
      Organize the Excellence
    </p>
  </header>

  <!-- Main Content -->
  <main class="flex-1 w-full max-w-2xl mx-auto px-6">
    <div class="bg-card-bg border border-border-zinc rounded-sm shadow-2xl overflow-hidden">
      <!-- Status Bar -->
      <div class="flex items-center gap-3 px-8 py-5 border-b border-border-zinc bg-zinc-900/50">
        <div class="h-2.5 w-2.5 rounded-full bg-wera-green animate-pulse"></div>
        <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest">System Initializing...</span>
      </div>

      <!-- Content -->
      <div class="px-8 py-10">
        <h2 class="text-2xl font-bold mb-5">精密工具收纳 & 3D 打印生态</h2>
        
        <p class="text-zinc-400 mb-10 leading-relaxed">
          我们正在为 <strong class="text-zinc-200">Wera / PB Swiss / Knipex</strong> 等顶级工具构建数字时代的物理秩序。基于 <strong class="text-zinc-200">Bambu Lab</strong> 的精密制造逻辑，Ruimakes 品牌站即将上线。
        </p>

        <!-- Product Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="border border-border-zinc p-5 hover:border-wera-green transition-colors duration-300 group cursor-pointer">
            <div class="text-xs text-zinc-500 mb-2 uppercase tracking-wider">01 / Tool-Org</div>
            <div class="font-bold text-base text-zinc-100 group-hover:text-wera-green transition-colors">精密收纳系列</div>
          </div>
          <div class="border border-border-zinc p-5 hover:border-wera-green transition-colors duration-300 group cursor-pointer">
            <div class="text-xs text-zinc-500 mb-2 uppercase tracking-wider">02 / Workstation</div>
            <div class="font-bold text-base text-zinc-100 group-hover:text-wera-green transition-colors">拓竹避震工作台</div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="text-center py-16 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES SECURITY LABS // RUIS-MBP-15
  </footer>
</Layout>