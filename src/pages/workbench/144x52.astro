---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "144x52 费斯托x5 | ruimakes";
const pageDesc = "1440×520×800mm 超大台面拓竹工作台，标配费斯托 M112×3+M237×2 五只工具箱，适配65L电子干燥箱（可容纳2台），北美樱桃木实木桌面。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/144-52-效果图.webp" alt="费斯托x5 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            144x52 <span class="text-wera-green">费斯托x5</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">1440×520×800mm 超大台面拓竹工作台，标配费斯托 M112×3+M237×2 五只工具箱，适配65L电子干燥箱（可容纳2台），北美樱桃木实木桌面。</p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥3,280</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="#" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">

    <div class="mb-8 text-sm text-zinc-500"><span class="text-wera-green font-bold">外尺寸：</span>外尺寸：长：1440mm；宽：40cm（P系列）/ 52cm（H系列）；高：800mm</div>

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">144 超大台面</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">1440×520mm 超大工作台面，可同时容纳多台设备和工具，桌面更大更从容。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托五工具箱</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配费斯托 M112×3+M237×2 五只工具箱，分类收纳，取用方便。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">适配65L干燥箱</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">预留65L电子干燥箱位置（38×39×52cm），可并排容纳2台打印机。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">六福马轮+中支撑</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">40S（4只）+ 40F（2只中部支撑），共6只福马轮，载重300KG，稳固不晃。</p>
      </div>

    </div>

    <ProductSpecs
      brand="BambuLab"
      material="欧标3030Q铝型材 + 北美樱桃实木桌面"
      compatibility="Bambu Lab X1 / P1 / A1 系列"
      features={["费斯托五工具箱(M112×3+M237×2)", "适配65L干燥箱(可容纳2台)", "六福马轮+中支撑(载重300KG)", "北美樱桃木桌面"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/144-52-效果图.webp" alt="144x52 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/144-52-效果图2.webp" alt="144x52 双机布局" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/144-52-买家秀1.webp" alt="144x52 买家秀1" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/144-52-买家秀2.webp" alt="144x52 买家秀2" class="rounded-sm border border-border-zinc" />
    </div>

    <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
      &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
    </footer>
  </main>
</Layout>
