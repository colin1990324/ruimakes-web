---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "144x52 费斯托x5 | ruimakes";
const pageDesc = "1440×520×800mm 拓竹工作台，标配费斯托五只工具箱，适配65L电子干燥箱，北美樱桃木实木桌面。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img id="hero-img" src="/images/workstation/144-52-效果图.webp" alt="144x52 费斯托x5 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            144x52 <span id="hero-subtitle" class="text-wera-green">费斯托x5</span>
          </h1>
          <p class="text-zinc-400 mb-4 leading-relaxed" id="hero-desc">1440×520×800mm 拓竹工作台，标配费斯托五只工具箱，适配65L电子干燥箱，北美樱桃木实木桌面。</p>
          <div class="mb-4">
            <span id="dim-note" class="text-sm text-zinc-500"><span class="text-wera-green font-bold">外尺寸：</span><span id="dim-text">1440×52×80cm</span></span>
          </div>
          <div class="flex items-center gap-4 mb-4">
            <span id="hero-price" class="text-2xl font-bold text-wera-green">¥3,280</span>
            <span id="hero-price-suffix" class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <div class="flex gap-3 flex-wrap mb-4">
            <button
              class="variant-btn px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-wera-green rounded-sm text-left transition-all"
              data-subtitle="费斯托x5"
              data-price="¥3,280"
              data-price-suffix="/ 含安装配件"
              data-cta="咨询购买"
              data-main-image="/images/workstation/144-52-效果图.webp"
              data-dim="1440×52×80cm"
            >
              <span class="text-wera-green font-bold text-sm">144x52 费斯托x5</span>
            </button>
            <button
              class="variant-btn px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-wera-green rounded-sm text-left transition-all"
              data-subtitle="费斯托x3"
              data-price="¥2,780"
              data-price-suffix="/ 含安装配件"
              data-cta="咨询购买"
              data-main-image="/images/workstation/144长度 费斯托x3.webp"
              data-dim="1440×52×80cm"
            >
              <span class="text-wera-green font-bold text-sm">144x52 费斯托x3</span>
            </button>
          </div>
          <a href="/contact" id="hero-cta" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托x5</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配费斯托 M112×3+M237×2 五只工具箱。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">标配定制洞洞板</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配定制金属/亚克力洞洞板。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">适配65L干燥箱</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">预留65L电子干燥箱位置。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">北美樱桃木桌面</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">北美进口樱桃原木多拼。</p>
      </div>
    </div>

    <ProductSpecs
      brand="BambuLab"
      material="欧标3030Q铝型材 + 北美樱桃实木桌面"
      compatibility="Bambu Lab H / X / P / A 系列"
      features={["费斯托x5", "标配定制洞洞板", "适配65L干燥箱", "北美樱桃木桌面"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/144-52-效果图.webp" alt="144x52 费斯托x5 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/144长度 费斯托x3.webp" alt="144x52 费斯托x3 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/IMG_6810.webp" alt="144x52 买家秀1" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/IMG_6994.webp" alt="144x52 买家秀2" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/IMG_6995.webp" alt="144x52 买家秀3" class="rounded-sm border border-border-zinc" />
    </div>

    <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
      &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
    </footer>
  </main>

  <script>
    const buttons = document.querySelectorAll('.variant-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('hero-subtitle').textContent = btn.dataset.subtitle;
        document.getElementById('hero-price').textContent = btn.dataset.price;
        document.getElementById('hero-price-suffix').textContent = btn.dataset.priceSuffix;
        document.getElementById('hero-cta').textContent = btn.dataset.cta;
        document.getElementById('hero-img').src = btn.dataset.mainImage;
        document.getElementById('hero-img').alt = btn.dataset.subtitle + ' 主图';
        document.getElementById('dim-text').textContent = btn.dataset.dim;
      });
    });
  </script>
</Layout>