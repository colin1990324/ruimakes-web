---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "50x40 费斯托工具车 | ruimakes";
const pageDesc = "500×400mm 紧凑型费斯托工具车工作台，完美适配工具车系统，适合空间有限的用户。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/50-40-买家秀.webp" alt="50x40 费斯托工具车 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            50x40 <span class="text-wera-green">费斯托工具车</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            500×400mm 紧凑型费斯托工具车工作台，完美适配费斯托工具车系统，30kg 承重，适合空间有限的用户。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="/contact" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">紧凑设计</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">500×400mm 紧凑台面，适配空间有限的工作环境。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托兼容</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">完美适配费斯托工具车，快速拆装，移动便捷。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">30kg 承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">加厚材质，稳固支撑单台打印机和工具。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">工具集成</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">工具车与工作台无缝结合，取用工具更方便。</p>
      </div>
    </div>

    <ProductSpecs brand="BambuLab" material="PETG-CF (碳纤维增强)" compatibility="Bambu Lab X1 / P1 / A1 系列" features={["紧凑设计", "费斯托兼容", "30kg承重", "工具集成"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/50-40-买家秀.webp" alt="50x40 费斯托工具车 买家秀" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
  </footer>

  <script>
    setTimeout(function() {
      // 完整翻译表
      const t = {
        "zh": {},
        "en": {
          "CTA": "Contact to Buy",
          "Design": "Design Concept", 
          "Gallery": "Product Gallery",
          "Specifications": "Specifications",
          "Dimensions": "Dimensions:",
          "Subtitle": "Festool x3 (P Series)",
          "PriceSuffix": "/ Including Installation",
          // 设计理念卡片
          "费斯托三工具箱": "Festool Tool Boxes",
          "标配费斯托 M112+M137+M187 三只工具箱，取用工具更方便。": "Includes Festool M112+M137+M187 three tool boxes for easy access.",
          "30L干燥箱适配": "30L Dry Box Fit",
          "预留30L电子干燥箱位置（29×32×41.5cm），干燥耗材即取即用。": "Reserved 30L electronic dry box position (29×32×41.5cm), dry consumables ready to use.",
          "200kg承重": "200kg Load Bearing",
          "欧标3030Q铝型材框架，200kg稳固支撑，单台设备轻松承载。": "Euro 3030Q aluminum frame, 200kg stable support, single equipment easy load.",
          "北美樱桃木桌面": "North American Cherry Wood Desktop",
          "北美进口樱桃原木多拼，2cm厚台面，天然纹理温润有质感。": "North American imported cherry multi拼接, 2cm thick desktop, natural texture warm and textured.",
          // Specifications
          "Target": "Target:",
          "Material": "Material:",
          "Compatibility": "Compatibility:",
          "Bambu Lab Ecosystem": "Bambu Lab Ecosystem",
          "欧标3030Q铝型材 + 北美樱桃实木桌面": "Euro 3030Q Aluminum + North American Cherry Wood",
          "P系列: X/P/A 系列, H系列: H/X/P/A 系列": "P Series: X/P/A Series, H Series: H/X/P/A Series"
        }
      };
      const lang = new URLSearchParams(location.search).get("lang") || "zh";
      if (lang === "en") {
        // 翻译函数 - 替换匹配的中文
        function translateElement(el, key) {
          if (t.en[key]) el.textContent = t.en[key];
        }
        // CTA 
        document.querySelectorAll("#hero-cta").forEach(el => el.textContent = t.en.CTA);
        // 副标题
        const subtitle = document.querySelector("#hero-subtitle");
        if (subtitle && t.en[subtitle.textContent]) subtitle.textContent = t.en[subtitle.textContent];
        // 价格后缀
        const priceSuffix = document.querySelector("#hero-price-suffix");
        if (priceSuffix) priceSuffix.textContent = t.en.PriceSuffix;
        // 所有 h2 标题
        document.querySelectorAll("h2").forEach(el => {
          if (el.textContent.includes("设计理念")) el.textContent = t.en.Design;
          if (el.textContent.includes("产品图赏")) el.textContent = t.en.Gallery;
          if (el.textContent.includes("Specifications")) el.textContent = t.en.Specifications;
        });
        // h3 设计卡片标题
        document.querySelectorAll("#design-cards h3").forEach(el => {
          if (t.en[el.textContent]) el.textContent = t.en[el.textContent];
        });
        // p 设计卡片描述
        document.querySelectorAll("#design-cards p").forEach(el => {
          if (t.en[el.textContent]) el.textContent = t.en[el.textContent];
        });
        // Specifications 标签
        document.querySelectorAll(".font-mono.text-sm .flex.gap-4").forEach(el => {
          const spans = el.querySelectorAll("span");
          spans.forEach(span => {
            if (t.en[span.textContent]) span.textContent = t.en[span.textContent];
          });
        });
      }
    }, 100);
  </script>




</Layout>