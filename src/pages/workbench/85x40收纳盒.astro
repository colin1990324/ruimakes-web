---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "85x40 收纳盒 | ruimakes";
const pageDesc = "850×400mm 收纳盒集成工作台，底层抽屉设计，工具配件触手可及，适合入门用户。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/85x40-收纳盒-买家秀.webp" alt="85x40 收纳盒 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            85x40 <span class="text-wera-green">收纳盒</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            850×400mm 收纳盒集成工作台，底层抽屉设计集成工具收纳，PETG-CF 材质，40kg 承重，适合入门用户。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="#" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">收纳集成</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">底层抽屉集成收纳设计，常用配件触手可及。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">模块化扩展</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">抽屉模块可拆卸替换，根据需求定制收纳方案。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">40kg 承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">加厚 PETG-CF 材质，稳固支撑单台设备。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">入门首选</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">高性价比入门之选，满足基础打印需求。</p>
      </div>
    </div>

    <ProductSpecs brand="BambuLab" material="PETG-CF (碳纤维增强)" compatibility="Bambu Lab X1 / P1 / A1 系列" features={["收纳集成", "模块化扩展", "40kg承重", "入门首选"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/85x40-收纳盒-买家秀.webp" alt="85x40 收纳盒 买家秀" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
  </footer>
</Layout>