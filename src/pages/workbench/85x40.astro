---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "85x40 费斯托 | ruimakes";
const pageDesc = "850×400×650mm / 850×520×650mm 拓竹工作台，标配费斯托三/四只工具箱，适配30L电子干燥箱，北美樱桃木实木桌面。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img id="hero-img" src="/images/workstation/85x40x3-效果图.webp" alt="费斯托x3 (P系列) 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            85x40 <span id="hero-subtitle" class="text-wera-green">费斯托x3 (P系列)</span>
          </h1>
          <p class="text-zinc-400 mb-4 leading-relaxed" id="hero-desc">850×400×650mm / 850×520×650mm 拓竹工作台，标配费斯托三/四只工具箱，适配30L电子干燥箱，北美樱桃木实木桌面。</p>
          <div id="dim-note" class="mb-4 text-sm text-zinc-500"><span class="text-wera-green font-bold">外尺寸：</span><span id="dim-text">长：850mm；宽：40cm（P系列）；高：650mm</span></div>
          <div class="flex items-center gap-4 mb-8">
            <span id="hero-price" class="text-2xl font-bold text-wera-green">¥2,080</span>
            <span id="hero-price-suffix" class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="/contact" id="hero-cta" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Variant Selector -->
  <div class="max-w-5xl mx-auto px-6 mb-8">
    <div class="flex gap-3 flex-wrap">
        <button
          class="variant-btn flex-1 px-4 py-3 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-wera-green rounded-sm text-left transition-all"
          data-subtitle="费斯托x3 (P系列)"
          data-price="¥2,080"
          data-price-suffix="/ 含安装配件"
          data-cta="咨询购买"
          data-main-image="/images/workstation/85x40x3-效果图.webp"
          data-dim="850×40cm（P系列）×650mm"
        >
          <div class="text-wera-green font-bold text-sm">费斯托x3 (P系列)</div>
          <div class="text-zinc-400 text-xs mt-1">¥2,080</div>
        </button>
        <button
          class="variant-btn flex-1 px-4 py-3 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-wera-green rounded-sm text-left transition-all"
          data-subtitle="费斯托 (H系列)"
          data-price="¥ 咨询"
          data-price-suffix="/ 含安装配件"
          data-cta="咨询购买"
          data-main-image="/images/workstation/85x40x3-效果图.webp"
          data-dim="850×52cm（H系列）×650mm"
        >
          <div class="text-wera-green font-bold text-sm">费斯托 (H系列)</div>
          <div class="text-zinc-400 text-xs mt-1">¥ 咨询</div>
        </button>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托三工具箱</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配费斯托 M112+M137+M187 三只工具箱，取用工具更方便。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">30L干燥箱适配</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">预留30L电子干燥箱位置（29×32×41.5cm），干燥耗材即取即用。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">200kg承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">欧标3030Q铝型材框架，200kg稳固支撑，单台设备轻松承载。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">北美樱桃木桌面</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">北美进口樱桃原木多拼，2cm厚台面，天然纹理温润有质感。</p>
      </div>
    </div>

    <ProductSpecs
      brand="BambuLab"
      material="欧标3030Q铝型材 + 北美樱桃实木桌面"
      compatibility="P系列: X/P/A 系列, H系列: H/X/P/A 系列"
      features={["费斯托三工具箱(M112+M137+M187)", "适配30L干燥箱", "200kg承重", "北美樱桃木桌面"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/85x40x3-效果图.webp" alt="85x40 费斯托 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/85x40x3-买家秀1.webp" alt="85x40 费斯托 买家秀1" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/85x40x3-买家秀2.webp" alt="85x40 费斯托 买家秀2" class="rounded-sm border border-border-zinc" />
    </div>

    <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
      &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
    </footer>
  </main>

  <script>
    const buttons = document.querySelectorAll('.variant-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('hero-subtitle').textContent = btn.dataset.subtitle;
        document.getElementById('hero-price').textContent = btn.dataset.price;
        document.getElementById('hero-price-suffix').textContent = btn.dataset.priceSuffix;
        document.getElementById('hero-cta').textContent = btn.dataset.cta;
        document.getElementById('hero-img').src = btn.dataset.mainImage;
        document.getElementById('hero-img').alt = btn.dataset.subtitle + ' 主图';
        document.getElementById('dim-text').textContent = btn.dataset.dim;
      });
    });
  </script>

  <script>
    setTimeout(function() {
      const translations = {
        "zh": {},
        "en": {
          "CTA": "Contact to Buy",
          "Design": "Design Concept",
          "Gallery": "Product Gallery",
          "Specifications": "Specifications",
          "Dimensions": "Dimensions:",
          "Subtitle": "Festool x3 (P Series)",
          "PriceSuffix": "/ Including Installation"
        }
      };
      const lang = new URLSearchParams(location.search).get("lang") || "zh";
      if (lang === "en") {
        // CTA 按钮
        document.querySelectorAll("#hero-cta").forEach(el => el.textContent = translations.en.CTA);
        // 副标题
        const subtitle = document.querySelector("#hero-subtitle");
        if (subtitle) subtitle.textContent = translations.en.Subtitle;
        // 价格后缀
        const priceSuffix = document.querySelector("#hero-price-suffix");
        if (priceSuffix) priceSuffix.textContent = translations.en.PriceSuffix;
        // 标题 h2
        document.querySelectorAll("h2").forEach(el => {
          if (el.textContent.includes("设计理念")) el.textContent = translations.en.Design;
          if (el.textContent.includes("产品图赏")) el.textContent = translations.en.Gallery;
          if (el.textContent.includes("Specifications")) el.textContent = translations.en.Specifications;
        });
        // 外尺寸标签
        document.querySelectorAll("span.font-bold").forEach(el => {
          if (el.textContent.includes("外尺寸")) el.textContent = translations.en.Dimensions;
        });
      }
    }, 100);
  </script>




</Layout>
