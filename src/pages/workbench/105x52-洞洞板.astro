---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "105x52 洞洞板 | ruimakes";
const pageDesc = "1050×520×770mm 拓竹工作台，标配定制金属洞洞板（46×60×1mm），磁吸滑轨可推拉收纳工具，桌面可并排容纳2台X/P系列打印机，北美樱桃木实木桌面。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/105-52-洞洞板-效果图.webp" alt="洞洞板 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            105x52 <span class="text-wera-green">洞洞板</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">1050×520×770mm 拓竹工作台，标配定制金属洞洞板（46×60×1mm），磁吸滑轨可推拉收纳工具，桌面可并排容纳2台X/P系列打印机，北美樱桃木实木桌面。</p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥1,980</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="/contact" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">

    <div class="mb-8 text-sm text-zinc-500"><span class="text-wera-green font-bold">外尺寸：</span>外尺寸：长：1050mm；宽：52cm（H系列）；高：770mm</div>

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">标配定制洞洞板</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配46×60×1mm定制金属洞洞板，含磁吸滑轨可推拉收纳，取放工具随手完成。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">三区布局</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">桌面左中区域可并排容纳2台X/P系列打印机，右下兼容H系列打印机，空间利用更高效。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">200kg承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">欧标3030Q铝型材框架，200kg稳固支撑，多台设备满载运行依然稳如磐石。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">北美樱桃木桌面</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">北美进口樱桃原木多拼，2cm厚台面，天然纹理温润有质感。</p>
      </div>

    </div>

    <ProductSpecs
      brand="BambuLab"
      material="欧标3030Q铝型材 + 北美樱桃实木桌面"
      compatibility="Bambu Lab H / X / P / A 系列"
      features={["标配定制洞洞板", "三区打印机布局", "200kg承重", "北美樱桃木桌面"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/105-52-洞洞板-效果图.webp" alt="105x52 洞洞板 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/105-52-洞洞板-买家秀1.webp" alt="105x52 洞洞板 买家秀" class="rounded-sm border border-border-zinc" />
    </div>

    <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
      &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
    </footer>
  </main>

  <script>
    setTimeout(function() {
      const translations = {
        "zh": {},
        "en": {
          "CTA": "Contact to Buy",
          "Design": "Design Concept",
          "Gallery": "Product Gallery"
        }
      };
      const lang = new URLSearchParams(location.search).get("lang") || "zh";
      if (lang === "en") {
        document.querySelectorAll("#hero-cta").forEach(el => el.textContent = translations.en.CTA);
        document.querySelectorAll("h2").forEach(el => {
          if (el.textContent.includes("设计理念")) el.textContent = translations.en.Design;
        });
      }
    }, 100);
  </script>




</Layout>
