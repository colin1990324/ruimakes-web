---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "85x40 费斯托x3 | ruimakes";
const pageDesc = "850×400×650mm 拓竹工作台，标配费斯托 M112+M137+M187 三只工具箱，适配30L电子干燥箱，北美樱桃木实木桌面。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/85x40x3-效果图.webp" alt="85x40 费斯托x3 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            85x40 <span class="text-wera-green">费斯托x3</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">850×400×650mm 拓竹工作台，标配费斯托 M112+M137+M187 三只工具箱，适配30L电子干燥箱，北美樱桃木实木桌面。</p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥2,080</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="#" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">

    <div class="mb-8 text-sm text-zinc-500"><span class="text-wera-green font-bold">外尺寸：</span>外尺寸：长：850mm；宽：40cm（P系列）/ 52cm（H系列）；高：650mm</div>

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托三工具箱</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">标配费斯托 M112+M137+M187 三只工具箱，取用工具更方便。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">30L干燥箱适配</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">预留30L电子干燥箱位置（29×32×41.5cm），干燥耗材即取即用。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">200kg 承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">欧标3030Q铝型材框架，200kg稳固支撑，单台设备轻松承载。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">北美樱桃木桌面</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">北美进口樱桃原木多拼，2cm厚台面，天然纹理温润有质感。</p>
      </div>

    </div>

    <ProductSpecs
      brand="BambuLab"
      material="欧标3030Q铝型材 + 北美樱桃实木桌面"
      compatibility="Bambu Lab X1 / P1 / A1 系列"
      features={["费斯托三工具箱(M112+M137+M187)", "适配30L干燥箱", "200kg承重", "北美樱桃木桌面"]}
    />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/85x40x3-效果图.webp" alt="85x40 费斯托x3 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/85x40x3-买家秀1.webp" alt="85x40 费斯托x3 买家秀1" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/85x40x3-买家秀2.webp" alt="85x40 费斯托x3 买家秀2" class="rounded-sm border border-border-zinc" />
    </div>

    <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
      &copy; 2026 RUIMAKES ®️ DESIGN LABS // Driven by Openclaw
    </footer>
  </main>
</Layout>
