---
import Layout from '../../layouts/Layout.astro';
import ProductSpecs from '../../components/ProductSpecs.astro';

const pageTitle = "97x52 费斯托x4 抽板x2 | ruimakes";
const pageDesc = "970×520mm 费斯托四轴双抽板工作台，双工具抽屉设计，集成双 AMS，适合专业用户。";
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="w-full bg-zinc-900 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img src="/images/workstation/97x52-2ams-效果图1.webp" alt="97x52 费斯托x4 抽板x2 主图" class="w-full rounded-sm shadow-2xl border border-border-zinc" />
        </div>
        <div>
          <div class="text-xs text-wera-green mb-3 uppercase tracking-widest font-bold">Bambu Lab Workstation</div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-zinc-100 mb-4">
            97x52 <span class="text-wera-green">费斯托x4 抽板x2</span>
          </h1>
          <p class="text-zinc-400 mb-8 leading-relaxed">
            970×520mm 费斯托四轴双抽板工作台，双工具抽屉设计，集成双 AMS 抽板，50kg 承重，适合专业用户。
          </p>
          <div class="flex items-center gap-4 mb-8">
            <span class="text-2xl font-bold text-wera-green">¥1 咨询</span>
            <span class="text-zinc-500 text-sm">/ 含安装配件</span>
          </div>
          <a href="#" class="inline-block bg-wera-green text-bg-dark px-8 py-3 font-bold text-sm uppercase tracking-wider hover:bg-emerald-400 transition-colors">咨询购买</a>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider">设计理念</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">费斯托四轴</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">四轴定位系统，完美兼容费斯托工具车系列。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">双工具抽屉</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">双抽屉设计，常用工具和配件分门别类，触手可及。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">双 AMS 集成</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">集成双 AMS 抽板，多色打印线材管理更高效。</p>
      </div>
      <div class="bg-card-bg border border-border-zinc rounded-sm p-6">
        <h3 class="text-lg font-bold text-wera-green mb-3">50kg 承重</h3>
        <p class="text-zinc-400 text-sm leading-relaxed">加厚 PETG-CF 材质，稳固支撑设备。</p>
      </div>
    </div>

    <ProductSpecs brand="BambuLab" material="PETG-CF (碳纤维增强)" compatibility="Bambu Lab X1 / P1 / A1 系列" features={["费斯托四轴", "双工具抽屉", "双AMS集成", "50kg承重"]} />

    <h2 class="text-2xl font-bold text-zinc-100 mb-8 uppercase tracking-wider mt-16">产品图赏</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/workstation/97x52-2ams-效果图1.webp" alt="97x52 费斯托x4 抽板x2 效果图" class="rounded-sm border border-border-zinc" />
      <img src="/images/workstation/97x52-x4抽板2-买家秀.webp" alt="97x52 费斯托x4 抽板x2 买家秀" class="rounded-sm border border-border-zinc" />
    </div>
  </main>

  <footer class="text-center py-12 text-zinc-700 text-xs uppercase tracking-widest">
    &copy; 2026 RUIMAKES SECURITY LABS // RUIS-MBP-15
  </footer>
</Layout>